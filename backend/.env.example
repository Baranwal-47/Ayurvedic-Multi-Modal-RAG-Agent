GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_TEXT_COLLECTION=text_chunks
QDRANT_IMAGE_COLLECTION=image_chunks
IMAGE_STORAGE_PATH=./data/images
GOOGLE_APPLICATION_CREDENTIALS=/absolute/path/to/service-account.json
# Optional: use us-vision.googleapis.com only if you need US-only processing
VISION_API_ENDPOINT=
EMBEDDING_MODEL_NAME=BAAI/bge-m3
EMBEDDING_USE_FP16=true
EMBEDDING_BATCH_SIZE=12

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=ayurveda-images
CLOUDINARY_UPLOAD_RETRIES=3
CLOUDINARY_RETRY_BASE_SEC=1.0
CLOUDINARY_CONNECT_TIMEOUT_SEC=10
CLOUDINARY_READ_TIMEOUT_SEC=300

LLM_PROVIDER=groq
GROQ_MODEL=llama-3.3-70b-versatile
RERANKER_MODEL_NAME=BAAI/bge-reranker-v2-m3
RERANKER_BATCH_SIZE=8
TEXT_CANDIDATE_TOP_K=20
RERANK_TOP_K=12
QUERY_EMBED_CACHE_SIZE=128
PREWARM_MODELS_ON_STARTUP=true
FRONTEND_ORIGINS=http://localhost:3000,http://127.0.0.1:3000

QDRANT_UPSERT_RETRIES=3
QDRANT_UPSERT_RETRY_WAIT_SEC=2
