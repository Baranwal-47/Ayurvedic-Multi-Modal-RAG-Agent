GROQ_API_KEY=your_groq_key_here
GEMINI_API_KEY=your_gemini_key_here
QDRANT_URL=https://your-cluster.qdrant.io
QDRANT_API_KEY=your_qdrant_api_key
QDRANT_TEXT_COLLECTION=text_chunks
QDRANT_IMAGE_COLLECTION=image_chunks
IMAGE_STORAGE_PATH=./data/images

# Cloudinary image storage
CLOUDINARY_CLOUD_NAME=your_cloud_name
CLOUDINARY_API_KEY=your_cloudinary_api_key
CLOUDINARY_API_SECRET=your_cloudinary_api_secret
CLOUDINARY_UPLOAD_FOLDER=ayurveda-images
CLOUDINARY_UPLOAD_RETRIES=3
CLOUDINARY_RETRY_BASE_SEC=1.0
CLOUDINARY_CONNECT_TIMEOUT_SEC=10
CLOUDINARY_READ_TIMEOUT_SEC=300

LLM_PROVIDER=groq

# Large-PDF memory controls
# Docling batching: set explicit page window size. 0 means auto mode.
DOCLING_PAGE_BATCH_SIZE=0
# Auto batching kicks in for PDFs with at least this many pages.
DOCLING_AUTO_BATCH_MIN_PAGES=120
# Auto batching page window size when enabled.
DOCLING_AUTO_BATCH_SIZE=4

# OCR routing batching and pacing for huge scanned PDFs.
OCR_PAGE_BATCH_SIZE=
OCR_AUTO_BATCH_MIN_PAGES=120
OCR_AUTO_BATCH_SIZE=8
OCR_BATCH_COOLDOWN_SEC=0